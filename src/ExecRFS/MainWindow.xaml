<Window x:Class="ExecRFS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        xmlns:local="clr-namespace:ExecRFS.Components.Shared"
        Title="ExecRFS — RemoteFileSync Manager"
        Width="1200" Height="800" MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#0d1117">
    <blazor:BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
        <blazor:BlazorWebView.RootComponents>
            <blazor:RootComponent Selector="#app" ComponentType="{x:Type local:AppRoot}" />
        </blazor:BlazorWebView.RootComponents>
    </blazor:BlazorWebView>
</Window>
